<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape: PC browser screen with navigation rail -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <!-- Navigation Rail (left side) -->
    <com.google.android.material.navigationrail.NavigationRailView
        android:id="@+id/navRail"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/md_theme_surfaceContainerLow"
        app:elevation="0dp"
        app:headerLayout="@null">

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:src="@drawable/ic_settings"
            android:tint="@color/md_theme_onSurfaceVariant"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings"
            android:preferKeepClear="true" />

        <ImageButton
            android:id="@+id/helpButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="4dp"
            android:padding="12dp"
            android:src="@drawable/ic_help"
            android:tint="@color/md_theme_onSurfaceVariant"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/help"
            android:preferKeepClear="true" />

        <ImageButton
            android:id="@+id/manuallyAddPc"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="4dp"
            android:padding="12dp"
            android:src="@drawable/ic_add"
            android:tint="@color/md_theme_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/add_pc_manually"
            android:preferKeepClear="true" />

    </com.google.android.material.navigationrail.NavigationRailView>

    <!-- Main content -->
    <FrameLayout
        android:id="@+id/pcFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="72dp">

        <LinearLayout
            android:id="@+id/no_pc_found_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="32dp">

            <ProgressBar
                android:id="@+id/pcs_loading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/md_theme_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/searching_pc"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:gravity="center" />
        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
