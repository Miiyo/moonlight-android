<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_surfaceContainerLow"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/title_add_pc"
            app:titleTextColor="@color/md_theme_onSurface"
            app:navigationIcon="@drawable/ic_add"
            app:navigationIconTint="@color/md_theme_onSurfaceVariant" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginTop="?attr/actionBarSize"
        android:layout_marginStart="0dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/hostTextInputLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/ip_hint"
            app:boxStrokeColor="@color/md_theme_primary"
            app:hintTextColor="@color/md_theme_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/hostTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:inputType="textNoSuggestions"
                android:imeOptions="actionDone"
                android:textColor="@color/md_theme_onSurface"
                android:preferKeepClear="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addPcButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@android:string/ok"
            android:preferKeepClear="true"
            app:cornerRadius="20dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
